# Copy to .env for local runs. In GitHub Actions this comes from a repo secret instead.
AISSTREAM_API_KEY=your_aisstream_api_key_here
# Optional: how long (seconds) to listen for a position before giving up. Default 180.
# AIS_WAIT_SECONDS=180
# Optional: fixes closer than this (metres) to the last point refresh it instead of
# appending, so a moored boat stays one dot. Default 50.
# AIS_MIN_MOVE_METERS=50
